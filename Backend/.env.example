# Flask Configuration
FLASK_DEBUG=False
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration

# ===== FOR ZOHO MAIL (Recommended) =====
MAIL_SERVER=smtp.zoho.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# Zoho Mail Credentials
# Use your Zoho email and password
# For better security, use App Password (see ZOHO_MAIL_SETUP.md)
MAIL_USERNAME=addi@aussupersource.com.au
MAIL_PASSWORD=Big@2006

# Email Settings
# MAIL_DEFAULT_SENDER: Email address that appears in the "From" field
MAIL_DEFAULT_SENDER=addi@aussupersource.com.au

# ADMIN_EMAIL: Where contact form submissions are sent to
ADMIN_EMAIL=sam@aussupersource.com.au

# Send confirmation email to users who submit the form
SEND_CONFIRMATION_EMAIL=True

